# Adjust User, Group, WorkingDirectory, FUNDING_EXCHANGE_CONFIG, FUNDING_ALERT_CONFIG, FUNDING_DB_PATH, and ExecStart before installing.

[Unit]
Description=Funding stack scheduler and dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/srv/funding
Environment=PYTHONUNBUFFERED=1
Environment=FUNDING_EXCHANGE_CONFIG=/srv/funding/config/exchanges.json
Environment=FUNDING_ALERT_CONFIG=/srv/funding/config/alerts.json
Environment=FUNDING_DB_PATH=/srv/funding/funding.db
ExecStart=/srv/funding/.venv/bin/python -m app.run_all_funding_stack --no-open-browser --host 0.0.0.0 --port 5000 --db-path /srv/funding/funding.db
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=180

[Install]
WantedBy=multi-user.target
